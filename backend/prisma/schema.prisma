generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model employees {
  id             Int       @id @default(autoincrement())
  employee_code  String    @unique @db.VarChar(20)
  first_name     String?   @db.VarChar(50)
  last_name      String?   @db.VarChar(50)
  email          String?   @unique @db.VarChar(100)
  phone          String?   @db.VarChar(20)
  city           String?   @db.VarChar(50)
  district       String?   @db.VarChar(50)
  province       String?   @db.VarChar(50)
  ward           String?   @db.VarChar(10)
  pan            String?   @db.VarChar(20)
  citizenship_no String?   @db.VarChar(20)
  job_title      String?   @db.VarChar(100)
  department     String?   @db.VarChar(50)
  dob            DateTime? @db.Date
  start_date     DateTime? @db.Date
  salary         Decimal?  @db.Decimal(10, 2)
  marital_status String?   @default("unmarried") @db.VarChar(20)
  gender         String?   @db.VarChar(20)
  employment_type String?  @default("Full-Time") @db.VarChar(50)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  password       String?   @db.VarChar(255)
  attendance     attendance[]
  leave_requests leave_requests[]
  time_requests  time_requests[]
}

model attendance {
  id          Int      @id @default(autoincrement())
  employee_id Int
  date        DateTime @db.Date
  punch_in_time        String?   @db.VarChar(10)
  punch_out_time       String?   @db.VarChar(10)
  punch_in_location   String?   @db.VarChar(255)
  punch_out_location  String?   @db.VarChar(255)
  punch_in_location_name   String?   @db.VarChar(255)
  punch_out_location_name  String?   @db.VarChar(255)
  
  punch_in_distance   Decimal?  @db.Decimal(10, 4)
  punch_out_distance  Decimal?  @db.Decimal(10, 4)
  location    String?  @db.VarChar(255)
  location_name String? @db.VarChar(255)
  distance    Decimal? @db.Decimal(10, 4)

  employee    employees @relation(fields: [employee_id], references: [id])
}

model leave_requests {
  id          Int       @id @default(autoincrement())
  employee_id Int
  leave_type  String    @db.VarChar(50)
  start_date  DateTime  @db.Date
  end_date    DateTime  @db.Date
  reason      String?   @db.Text
  status      String?   @default("Pending") @db.VarChar(20)
  created_at  DateTime? @default(now()) @db.Timestamp(6)

  employee    employees @relation(fields: [employee_id], references: [id])
}

model users {
  id       Int     @id @default(autoincrement())
  name     String? @db.VarChar(50)
  email    String? @unique @db.VarChar(100)
  password String? @db.VarChar(100)
  role     String? @default("hr") @db.VarChar(50)
}

model time_requests {
  id           Int       @id @default(autoincrement())
  employee_id  Int
  request_type String    @db.VarChar(50)
  date         DateTime  @db.Date
  time_in      String?   @db.VarChar(10)
  time_out     String?   @db.VarChar(10)
  reason       String?   @db.Text
  status       String?   @default("Pending") @db.VarChar(20)
  created_at   DateTime? @default(now()) @db.Timestamp(6)

  employee     employees @relation(fields: [employee_id], references: [id])
}

model anonymous_feedback {
  id         Int       @id @default(autoincrement())
  message    String    @db.Text
  category   String    @db.VarChar(50)
  status     String?   @default("Unread") @db.VarChar(20)
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

model password_resets {
  id         Int      @id @default(autoincrement())
  email      String
  otp        String   @db.VarChar(10)
  expires_at DateTime
  created_at DateTime @default(now())
}
